<?php
// ============================================
// 輕鐵班次顯示系統 (優化快取版)
// ============================================

// Start output buffering with compression
ob_start(function($buffer) {
    // 移除換行、多餘空格同標籤間嘅空白
    $search = array('/\n/', '/\s{2,}/', '/(\>)\s*(\<)/');
    $replace = array('', ' ', '$1$2');
    $buffer = preg_replace($search, $replace, $buffer);
    return ob_gzhandler($buffer, 5); // 繼續保持 Gzip
});
// 關閉錯誤顯示（生產環境）
ini_set('display_errors', 0);
error_reporting(0);

// ============================================
// 配置設定
// ============================================
const API_BASE_URL = 'https://rt.data.gov.hk/v1/transport/mtr/lrt/getSchedule/';
const API_TIMEOUT = 5; // 縮短為3秒
const DEFAULT_STATION_ID = '220';

// 快取配置
const CACHE_DIR = __DIR__ . '/cache/';
const CACHE_TIME = 10; // 伺服器快取20秒（輕鐵班次更新頻密）
const LOG_DIR = __DIR__ . '/logs/';

// HTTP標頭優化
header('Cache-Control: no-cache, must-revalidate');
header('Pragma: no-cache');
header('Expires: 0');
header('Content-Type: text/html; charset=utf-8');

// ============================================
// 錯誤處理函數
// ============================================
function logError(string $message): void {
    // 減少IO操作，只記錄重要錯誤
    static $errorCount = 0;
    $errorCount++;
    
    // 每10個錯誤記錄一次，避免過度寫入
    if ($errorCount % 10 !== 1) {
        return;
    }
    
    if (!is_dir(LOG_DIR)) {
        mkdir(LOG_DIR, 0755, true);
    }
    
    $logFile = LOG_DIR . 'error_' . date('Y-m-d') . '.log';
    $logMessage = '[' . date('Y-m-d H:i:s') . '] ' . $message . "\n";
    
    // 限制日誌檔案大小（約1000行）
    if (file_exists($logFile) && filesize($logFile) > 100000) {
        $lines = file($logFile);
        $lines = array_slice($lines, -500); // 保留最後500行
        file_put_contents($logFile, implode('', $lines));
    }
    
    file_put_contents($logFile, $logMessage, FILE_APPEND);
}

// ============================================
// 核心API請求函數（帶快取）
// ============================================
function fetchApiData(string $stationId): ?array {
    $url = API_BASE_URL . '?station_id=' . urlencode($stationId);
    
    $ch = curl_init();
    
    // ============================================
    // cURL 核心配置
    // ============================================
    curl_setopt($ch, CURLOPT_URL, $url);
    curl_setopt($ch, CURLOPT_RETURNTRANSFER, true);
    curl_setopt($ch, CURLOPT_TIMEOUT, API_TIMEOUT);
    curl_setopt($ch, CURLOPT_USERAGENT, 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36');
    
    // 【關鍵】強制使用 IPv4，解決你 Routing 改動後 IPv6 不通的問題
    curl_setopt($ch, CURLOPT_IPRESOLVE, CURL_IPRESOLVE_V4);
    
    // 如果 CloudFront 依然報 404，試試停用 SSL 驗證（排查用）
    // curl_setopt($ch, CURLOPT_SSL_VERIFYPEER, false);

    $response = curl_exec($ch);
    $httpCode = curl_getinfo($ch, CURLINFO_HTTP_CODE);
    $curlError = curl_error($ch);
    
    curl_close($ch);

    // ============================================
    // 錯誤處理
    // ============================================
    if ($response === false) {
        logError("cURL Failed for station $stationId: $curlError");
        return null;
    }

    if ($httpCode !== 200) {
        logError("API returned HTTP $httpCode for station $stationId. Response: " . substr($response, 0, 100));
        return null;
    }

    $data = json_decode($response, true);
    if (!$data || !isset($data['status']) || $data['status'] !== 1) {
        logError("Invalid JSON or Status 0 for station $stationId");
        return null;
    }

    return $data;
}

/**
 * 帶快取的API請求（主要優化點）
 */
function fetchApiDataWithCache(string $stationId): ?array {
    $cacheKey = "lrt_ram_" . $stationId;
    
    // 第一步：先睇 RAM (APCu) 有冇，呢度係微秒級，最快
    if (function_exists('apcu_fetch') && apcu_exists($cacheKey)) {
        return apcu_fetch($cacheKey);
    }

    // 第二步：RAM 冇先去攞 API
    $data = fetchApiData($stationId);
    
    if ($data) {
        // 攞到就塞入 RAM，設定 10 秒過期
        if (function_exists('apcu_store')) {
            apcu_store($cacheKey, $data, 10); 
        }
        // 同時更新原本嘅 File Cache 做備份
        @file_put_contents(CACHE_DIR . "station_$stationId.json", json_encode($data));
        return $data;
    }

    // 第三步：API 斷咗先讀 File Cache
    $cacheFile = CACHE_DIR . "station_$stationId.json";
    return file_exists($cacheFile) ? json_decode(file_get_contents($cacheFile), true) : null;
}
// ============================================
// HTML生成函數
// ============================================
function generateTable(?array $data): string {
    if (!$data || empty($data['platform_list'])) {
        return '<table class="table table-hover table-responsive" style="width:100%;"><tbody><tr><td colspan="4" class="text-center">無可用數據</td></tr></tbody></table>';
    }

    $output = '<table class="table table-hover table-responsive" style="width:100%;">';
    $output .= '<thead><tr class="table-secondary"><th>路綫</th><th>目的地</th><th>車卡數</th><th>下一班車</th></tr></thead><tbody>';

    foreach ($data['platform_list'] as $platform) {
        $platformId = htmlspecialchars($platform['platform_id'] ?? 'N/A', ENT_QUOTES, 'UTF-8');
        $output .= "<tr><td colspan='4' class='table-primary text-center'><strong>月台: $platformId</strong></td></tr>";

        foreach ($platform['route_list'] ?? [] as $route) {
            $routeNo = htmlspecialchars($route['route_no'] ?? 'N/A', ENT_QUOTES, 'UTF-8');
            $destCh = htmlspecialchars($route['dest_ch'] ?? 'N/A', ENT_QUOTES, 'UTF-8');
            $timeCh = htmlspecialchars($route['time_ch'] ?? 'N/A', ENT_QUOTES, 'UTF-8');
            $trainImg = !empty($route['train_length']) ? htmlspecialchars($route['train_length'], ENT_QUOTES, 'UTF-8') : '';
            $trainImgTag = $trainImg ? "<img src='$trainImg.png' alt='train' loading='lazy' style='max-height:24px;'>" : '-';

            $output .= "<tr><td><strong>$routeNo</strong></td><td>$destCh</td><td>$trainImgTag</td><td><strong>$timeCh</strong></td></tr>";
        }
    }

    $output .= '</tbody></table>';
    return $output;
}

// ============================================
// 主要邏輯
// ============================================

// 驗證車站ID
$stationId = filter_input(INPUT_GET, 'id', FILTER_VALIDATE_REGEXP, [
    'options' => ['regexp' => '/^\d{3}$/']
]) ?? DEFAULT_STATION_ID;

if ($stationId === false) {
    // 不記錄無效ID錯誤，直接顯示
    echo '<div id="error-message" style="text-align:center;color:#ff6f61;font-size:1rem;font-weight:500;margin:1rem;padding:0.75rem;background:#fff;border-radius:8px;box-shadow:0 2px 6px rgba(0,0,0,0.05);">無效的車站編號</div>';
    exit;
}

// 獲取數據（使用快取版本）
$data = fetchApiDataWithCache($stationId);

// 定義錯誤訊息（多次使用）
define('ERROR_MESSAGE', '<div id="error-message" style="text-align:center;color:#ff6f61;font-size:1rem;font-weight:500;margin:1rem;padding:0.75rem;background:#fff;border-radius:8px;box-shadow:0 2px 6px rgba(0,0,0,0.05);">無法載入輕鐵數據，請稍後再試！</div>');

if ($data === null) {
    echo ERROR_MESSAGE;
    exit;
}

// 輸出最後更新時間（加入快取狀態提示）
$lastUpdate = htmlspecialchars($data['system_time'] ?? '', ENT_QUOTES, 'UTF-8');
$cacheStatus = '';

if (isset($data['_cached'])) {
    $cacheAge = $data['_cache_age'] ?? 0;
    $statusClass = $cacheAge < 10 ? 'background:#e8f5e9;color:#2e7d32;' : 'background:#fff3cd;color:#856404;';
    
    if (isset($data['_cache_expired'])) {
        $cacheStatus = '<small style="'.$statusClass.';padding:2px 8px;border-radius:4px;margin-left:10px;">快取更新中 ('.($cacheAge).'秒前)</small>';
    } elseif (isset($data['_api_failed'])) {
        $cacheStatus = '<small style="background:#f8d7da;color:#721c24;padding:2px 8px;border-radius:4px;margin-left:10px;">使用快取數據 (API連接失敗)</small>';
    } else {
        $cacheStatus = '<small style="'.$statusClass.';padding:2px 8px;border-radius:4px;margin-left:10px;">快取數據 ('.$cacheAge.'秒前)</small>';
    }
}

echo "<p id='lastUpdate' style='font-size:1.1rem;font-weight:600;color:#4b5563;text-align:left;margin:1.5rem 0;padding-left:1rem;'>最後更新時間: $lastUpdate <br>$cacheStatus</p>";

// 輸出表格
echo generateTable($data);

// ============================================
// 添加前端JavaScript快取支持
// ============================================
?>
<script>
// 前端快取輔助函數
(function() {
    // 生成當前頁面內容的快取鍵
    const pageContent = document.getElementById('table')?.innerHTML + document.getElementById('lastUpdate')?.innerHTML;
    const cacheKey = 'lrt_page_cache_<?php echo $stationId; ?>_' + 
                     (new Date('<?php echo $data["system_time"] ?? date("Y-m-d H:i:s"); ?>')).getTime();
    
    // 儲存到localStorage（5分鐘有效期）
    try {
        const cacheData = {
            html: pageContent,
            timestamp: Date.now(),
            stationId: '<?php echo $stationId; ?>',
            systemTime: '<?php echo $data["system_time"] ?? ""; ?>'
        };
        localStorage.setItem(cacheKey, JSON.stringify(cacheData));
        
        // 清理舊快取（保留最近10個）
        const keys = [];
        for (let i = 0; i < localStorage.length; i++) {
            const key = localStorage.key(i);
            if (key.startsWith('lrt_page_cache_')) {
                keys.push(key);
            }
        }
        
        if (keys.length > 10) {
            keys.sort().slice(0, keys.length - 10).forEach(key => {
                localStorage.removeItem(key);
            });
        }
    } catch (e) {
        // localStorage可能已滿或不可用，忽略錯誤
    }
    
    // 監聽頁面刷新，嘗試使用快取
    document.addEventListener('DOMContentLoaded', function() {
        const cachedData = localStorage.getItem(cacheKey);
        if (cachedData) {
            const { html, timestamp } = JSON.parse(cachedData);
            const age = Date.now() - timestamp;
            
            // 如果快取在5秒內，可以考慮預載入
            if (age < 5000 && window.performance?.getEntriesByType) {
                console.log('前端快取有效:', age + 'ms前');
            }
        }
    });
})();
</script>
<?php
// ============================================
// 自動清理舊快取（每天一次）
// ============================================
function cleanupOldCache() {
    static $cleaned = false;
    if ($cleaned) return;
    
    $cleanupFile = CACHE_DIR . '.last_cleanup';
    $cleanupInterval = 86400; // 24小時
    
    if (!file_exists($cleanupFile) || 
        (time() - filemtime($cleanupFile)) > $cleanupInterval) {
        
        if (is_dir(CACHE_DIR)) {
            $files = glob(CACHE_DIR . 'station_*.json');
            foreach ($files as $file) {
                if (filemtime($file) < time() - 86400) { // 超過1天
                    @unlink($file);
                }
            }
        }
        
        @file_put_contents($cleanupFile, time());
    }
    
    $cleaned = true;
}

// 註冊清理函數（在請求結束後執行）
register_shutdown_function('cleanupOldCache');
?>